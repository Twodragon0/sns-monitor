FROM python:3.11-slim

WORKDIR /app

# 시스템 패키지 설치 (gcc 제거 - 대부분의 패키지는 pre-built wheels 사용)
# RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

# Python 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Flask, Redis 추가
RUN pip install --no-cache-dir flask redis requests anthropic openai

# 애플리케이션 코드 복사
COPY lambda_function.py .

# Flask 래퍼 생성 (분석기용)
RUN echo 'from flask import Flask, request, jsonify\n\
import lambda_function\n\
import redis\n\
import json\n\
import os\n\
\n\
app = Flask(__name__)\n\
redis_client = redis.Redis(\n\
    host=os.environ.get("REDIS_HOST", "redis"),\n\
    port=int(os.environ.get("REDIS_PORT", 6379)),\n\
    decode_responses=True\n\
)\n\
\n\
@app.route("/analyze", methods=["POST"])\n\
def analyze():\n\
    event = request.get_json() or {}\n\
    \n\
    # 캐시 확인\n\
    s3_key = event.get("s3_key", "")\n\
    cache_key = f"analysis:{s3_key}"\n\
    cached = redis_client.get(cache_key)\n\
    if cached:\n\
        print(f"Cache hit: {cache_key}")\n\
        return jsonify(json.loads(cached))\n\
    \n\
    # 분석 실행\n\
    context = {}\n\
    result = lambda_function.lambda_handler(event, context)\n\
    \n\
    # 캐시 저장 (1시간)\n\
    if result.get("statusCode") == 200:\n\
        redis_client.setex(cache_key, 3600, json.dumps(result))\n\
    \n\
    return jsonify(result)\n\
\n\
@app.route("/health", methods=["GET"])\n\
def health():\n\
    return jsonify({\n\
        "status": "healthy",\n\
        "redis": redis_client.ping()\n\
    })\n\
\n\
if __name__ == "__main__":\n\
    app.run(host="0.0.0.0", port=5000, threaded=True)\n\
' > app.py

# 포트 노출
EXPOSE 5000

# 실행
CMD ["python", "app.py"]
