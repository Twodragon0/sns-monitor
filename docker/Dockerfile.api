FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Application code
COPY backend/ .

# Create local-data directory structure
RUN mkdir -p /app/local-data/youtube/channels \
             /app/local-data/dcinside \
             /app/local-data/vuddy/comprehensive_analysis \
             /app/local-data/analysis

EXPOSE 8080

CMD ["python", "app.py"]
