            "장시간 ASMR 영상(3시간 이상)의 인기 증가",
            "빗소리, 백색소음 등 자연 사운드 콘텐츠 선호도 높음",
            "불면증 개선 및 스트레스 해소 목적의 시청자 증가",
            "해외 시청자 유입이 꾸준히 증가하는 추세"
          ]
        }
      }
    ];
  };

  // eslint-disable-next-line no-unused-vars
  const [selectedScan, setSelectedScan] = useState(null);
  const [platformSummary, setPlatformSummary] = useState(null);

  // AkaiV Studio 필터링 효과
  useEffect(() => {
    if (showArchiveStudioCreators && allVuddyCreators.length > 0) {
      const filtered = allVuddyCreators.filter(c => {
        const name = (c.name || '').toLowerCase();
        return name.includes('u32') || name.includes('여르미') || name.includes('한결') || 
               name.includes('비몽') || name.includes('샤르망') || name.includes('akaiv');
      });
      setVuddyCreators(filtered);
    } else if (!showArchiveStudioCreators && allVuddyCreators.length > 0) {
      setVuddyCreators(allVuddyCreators);
    }
  }, [showArchiveStudioCreators, allVuddyCreators]);

  // filteredScans는 더 이상 사용하지 않음 (최근 수집 데이터 섹션 제거됨)

  // 크리에이터 상세 내역 토글 함수
  const toggleCreatorDetails = (creatorName) => {
    setExpandedCreators(prev => ({
      ...prev,
      [creatorName]: !prev[creatorName]
    }));
  };

  // 플랫폼별 요약 통계 계산
  useEffect(() => {
    if (selectedPlatform === 'dcinside') {
      // DC인사이드 플랫폼 요약 통계 (dcinsideGalleries 데이터 사용)
      const totalGalleries = dcinsideGalleries.length;
      const totalPosts = dcinsideGalleries.reduce((sum, gallery) => sum + (gallery.total_posts || 0), 0);
      const totalComments = dcinsideGalleries.reduce((sum, gallery) => {
        return sum + (gallery.posts || []).reduce((commentSum, post) => {
          return commentSum + (post.comment_count || 0);
        }, 0);
      }, 0);

      // 감정 분석 집계
      let positiveCount = 0;
      let negativeCount = 0;

      dcinsideGalleries.forEach(gallery => {
        (gallery.posts || []).forEach(post => {
          const sentiment = analyzeSentiment(post.title + ' ' + (post.content || ''));
          if (sentiment === 'positive') positiveCount++;
          else if (sentiment === 'negative') negativeCount++;

          // 댓글 감정 분석
          (post.comments || []).forEach(comment => {
            const commentSentiment = analyzeSentiment(comment.text);
            if (commentSentiment === 'positive') positiveCount++;
            else if (commentSentiment === 'negative') negativeCount++;
          });
        });
      });

      setPlatformSummary({
        platform: 'dcinside',
        totalItems: totalGalleries,
        totalPosts,
        totalComments,
        positiveCount,
        negativeCount,
        galleries: dcinsideGalleries
      });
    } else if (selectedPlatform !== 'all') {
      const platformScans = scans.filter(scan => scan.platform === selectedPlatform);
      const totalItems = platformScans.length;
      const totalComments = platformScans.reduce((sum, scan) => sum + (scan.total_comments || 0), 0);
      const totalVideos = platformScans.reduce((sum, scan) => sum + (scan.videos_found || 0), 0);
      const totalTweets = platformScans.reduce((sum, scan) => sum + (scan.tweets_found || 0), 0);
      const totalPosts = platformScans.reduce((sum, scan) => sum + (scan.posts_found || 0), 0);
      const totalEntries = platformScans.reduce((sum, scan) => sum + (scan.entries_found || 0), 0);

      // YouTube 플랫폼의 경우 분석 데이터 집계
      let aggregatedAnalysis = null;
      let aggregatedCountryStats = null;
      let allCommentSamples = [];

      if (selectedPlatform === 'youtube') {
        // AkaiV Studio 관련 스캔 찾기 (키워드로 필터링)
        const archiveStudioScans = platformScans.filter(scan => {
          const keyword = (scan.keyword || '').toLowerCase();
          return keyword.includes('akaiv studio') ||
                 keyword.includes('akaiv');
        });

        // AkaiV Studio 스캔이 있으면 그것을 사용, 없으면 최신 스캔 사용
        const targetScans = archiveStudioScans.length > 0 ? archiveStudioScans : platformScans;
        const latestScan = targetScans.length > 0 ? targetScans[0] : null;

        if (latestScan) {
          if (latestScan.analysis) {
            aggregatedAnalysis = latestScan.analysis;
          }
          if (latestScan.country_stats) {
            aggregatedCountryStats = latestScan.country_stats;
          }
          if (latestScan.comment_samples && latestScan.comment_samples.length > 0) {
            allCommentSamples = latestScan.comment_samples;
          }
        }

        // AkaiV Studio 관련 스캔이 있으면 플래그 추가
        if (archiveStudioScans.length > 0) {
          // 이미 처리됨
        }
      }

      setPlatformSummary({
        platform: selectedPlatform,
        totalItems,
        totalComments,
        totalVideos,
        totalTweets,
        totalPosts,
        totalEntries,
        scans: platformScans,
        analysis: aggregatedAnalysis,
        country_stats: aggregatedCountryStats,
        comment_samples: allCommentSamples
      });
    } else {
      setPlatformSummary(null);
    }
  }, [selectedPlatform, scans, dcinsideGalleries]);

  if (loading) {
    return (
      <div className="dashboard-loading">
        <div className="spinner"></div>
        <p>데이터 로딩 중...</p>
      </div>
    );
  }

  return (
    <div className="dashboard">
      {/* 통계 카드 */}
      <div className="stats-section">
        <h2>📊 통계</h2>
        <div className="stats-grid">
          <div className="stat-card">
            <div className="stat-icon">📊</div>
            <div className="stat-content">
              <h3>총 수집 개수</h3>
              <p className="stat-value">
                {(() => {
                  // Vuddy 크리에이터 댓글 수
                  const vuddyComments = allVuddyCreators.reduce((sum, creator) =>
                    sum + (creator.comments?.length || 0), 0);

                  // DC인사이드 게시글 수 (total_posts 사용)
                  const dcPosts = dcinsideGalleries.reduce((sum, gallery) =>
                    sum + (gallery.total_posts || gallery.posts?.length || 0), 0);

                  return vuddyComments + dcPosts;
                })()}
              </p>
            </div>
          </div>
          <div className="stat-card">
            <div className="stat-icon">💬</div>
            <div className="stat-content">
              <h3>총 댓글 수</h3>
              <p className="stat-value">
                {(() => {
                  // Vuddy 크리에이터 댓글 수
                  const vuddyComments = allVuddyCreators.reduce((sum, creator) =>
                    sum + (creator.comments?.length || 0), 0);

                  // DC인사이드 총 댓글 수
                  const dcComments = dcinsideGalleries.reduce((sum, gallery) =>
                    sum + (gallery.total_comments || 0), 0);

                  return vuddyComments + dcComments;
                })()}
              </p>
            </div>
          </div>
          <div className="stat-card">
            <div className="stat-icon">📅</div>
            <div className="stat-content">
              <h3>최근 수집 날짜</h3>
              <p className="stat-value" style={{ fontSize: '1rem' }}>
                {(() => {
                  const dates = [];

                  // Vuddy 크리에이터 날짜
                  allVuddyCreators.forEach(creator => {
                    if (creator.last_crawled) dates.push(new Date(creator.last_crawled));
                  });

                  // DC인사이드 날짜 (crawled_at 사용)
                  dcinsideGalleries.forEach(gallery => {
                    if (gallery.crawled_at) dates.push(new Date(gallery.crawled_at));
                  });

                  if (dates.length === 0) return 'N/A';

                  const latestDate = new Date(Math.max(...dates));
                  return toKSTDate(latestDate.toISOString());
                })()}
              </p>
            </div>
          </div>
        </div>
      </div>

      {/* 플랫폼 필터 */}
      <div className="filter-section">
        <h2>🔍 플랫폼별 데이터</h2>
        <div className="platform-filters">
          <button 
            className={selectedPlatform === 'all' ? 'active' : ''}
            onClick={() => setSelectedPlatform('all')}
            title={`전체 데이터 보기 (${scans.length}개)`}
          >
            전체
            {scans.length > 0 && <span className="filter-count">({scans.length})</span>}
          </button>
          <button 
            className={selectedPlatform === 'youtube' ? 'active' : ''}
            onClick={() => setSelectedPlatform('youtube')}
            title={`YouTube 데이터만 보기 (${scans.filter(s => s.platform === 'youtube').length}개)`}
          >
            YouTube
            {scans.filter(s => s.platform === 'youtube').length > 0 && (
              <span className="filter-count">({scans.filter(s => s.platform === 'youtube').length})</span>
            )}
          </button>
          <button 
            className={selectedPlatform === 'telegram' ? 'active' : ''}
            onClick={() => setSelectedPlatform('telegram')}
            title={`Telegram 데이터만 보기 (${scans.filter(s => s.platform === 'telegram').length}개)`}
          >
            Telegram
            {scans.filter(s => s.platform === 'telegram').length > 0 && (
              <span className="filter-count">({scans.filter(s => s.platform === 'telegram').length})</span>
            )}
          </button>
          <button
            className={selectedPlatform === 'vuddy' ? 'active' : ''}
            onClick={() => setSelectedPlatform('vuddy')}
            title={`Vuddy 데이터만 보기 (${scans.filter(s => s.platform === 'vuddy').length}개)`}
          >
            Vuddy
            {scans.filter(s => s.platform === 'vuddy').length > 0 && (
              <span className="filter-count">({scans.filter(s => s.platform === 'vuddy').length})</span>
            )}
          </button>
          <button
            className={selectedPlatform === 'twitter' ? 'active' : ''}
            onClick={() => setSelectedPlatform('twitter')}
            title={`Twitter/X 데이터만 보기 (${scans.filter(s => s.platform === 'twitter').length}개)`}
          >
            Twitter/X
            {scans.filter(s => s.platform === 'twitter').length > 0 && (
              <span className="filter-count">({scans.filter(s => s.platform === 'twitter').length})</span>
            )}
          </button>
          <button
            className={selectedPlatform === 'dcinside' ? 'active' : ''}
            onClick={() => setSelectedPlatform('dcinside')}
            title={`DC인사이드 데이터만 보기 (${dcinsideGalleries.reduce((sum, g) => sum + (g.total_posts || 0), 0)}개)`}
          >
            DC인사이드
            {dcinsideGalleries.length > 0 && (
              <span className="filter-count">({dcinsideGalleries.reduce((sum, g) => sum + (g.total_posts || 0), 0)})</span>
            )}
          </button>
        </div>
        
        {/* 플랫폼별 요약 정보 */}
        {platformSummary && (
          <div className="platform-summary">
            <h3>
              {platformSummary.platform === 'youtube' && '📹'}
              {platformSummary.platform === 'telegram' && '💬'}
              {platformSummary.platform === 'rss' && '📰'}
              {platformSummary.platform === 'vuddy' && '🎭'}
              {platformSummary.platform === 'twitter' && '🐦'}
              {platformSummary.platform === 'instagram' && '📷'}
              {platformSummary.platform === 'facebook' && '👥'}
              {platformSummary.platform === 'threads' && '🧵'}
              {platformSummary.platform === 'dcinside' && '💬'}
              {' '}
              {platformSummary.platform === 'twitter' ? 'Twitter/X' :
               platformSummary.platform === 'instagram' ? 'Instagram' :
               platformSummary.platform === 'facebook' ? 'Facebook' :
               platformSummary.platform === 'threads' ? 'Threads' :
               platformSummary.platform === 'youtube' ? 'YouTube' :
               platformSummary.platform === 'telegram' ? 'Telegram' :
               platformSummary.platform === 'rss' ? 'RSS' :
               platformSummary.platform === 'vuddy' ? 'Vuddy' :
               platformSummary.platform === 'dcinside' ? 'DC인사이드' :
               platformSummary.platform.toUpperCase()} 플랫폼 요약
            </h3>
            {platformSummary.totalItems === 0 ? (
              <div className="summary-empty">
                <p>해당 플랫폼에서 수집된 데이터가 없습니다.</p>
                <div className="platform-guide">
                  {platformSummary.platform === 'youtube' && (
                    <p className="guide-text">
                      💡 YouTube 크롤러를 실행하여 영상과 댓글을 수집하세요.
                      <br />
                      키워드 예시: "AkaiV Studio", "AkaiV Studio", "Akaiv Studio" 등
                    </p>
                  )}
                  {platformSummary.platform === 'telegram' && (
                    <p className="guide-text">
                      💡 Telegram 크롤러를 실행하여 채널 메시지를 수집하세요.
                      <br />
                      채널 URL 예시: https://t.me/channel_name
                    </p>
                  )}
                  {platformSummary.platform === 'rss' && (
                    <p className="guide-text">
                      💡 RSS 크롤러를 실행하여 피드 항목을 수집하세요.
                      <br />
                      RSS 피드 URL을 설정하면 자동으로 수집됩니다.
                    </p>
                  )}
                  {platformSummary.platform === 'vuddy' && (
                    <p className="guide-text">
                      💡 Vuddy 크롤러를 실행하여 크리에이터 정보를 수집하세요.
                      <br />
                      vuddy.io의 크리에이터 목록을 자동으로 수집합니다.
                    </p>
                  )}
                  {platformSummary.platform === 'twitter' && (
                    <p className="guide-text">
                      💡 Twitter/X 크롤러를 실행하여 트윗과 댓글을 수집하세요.
                      <br />
                      키워드나 사용자명으로 검색하여 데이터를 수집할 수 있습니다.
                    </p>
                  )}
                  {platformSummary.platform === 'instagram' && (
                    <p className="guide-text">
                      💡 Instagram 크롤러를 실행하여 게시물과 댓글을 수집하세요.
                      <br />
                      해시태그나 계정명으로 검색하여 데이터를 수집할 수 있습니다.
                    </p>
                  )}
                  {platformSummary.platform === 'facebook' && (
                    <p className="guide-text">
                      💡 Facebook 크롤러를 실행하여 게시물과 댓글을 수집하세요.
                      <br />
                      페이지나 그룹의 게시물을 검색하여 데이터를 수집할 수 있습니다.
                    </p>
                  )}
                  {platformSummary.platform === 'threads' && (
                    <p className="guide-text">
                      💡 Threads 크롤러를 실행하여 게시물과 댓글을 수집하세요.
                      <br />
                      계정명이나 키워드로 검색하여 데이터를 수집할 수 있습니다.
                    </p>
                  )}
                  {platformSummary.platform === 'dcinside' && (
                    <p className="guide-text">
                      💡 DC인사이드 크롤러를 실행하여 갤러리 게시글과 댓글을 수집하세요.
                      <br />
                      갤러리 ID로 검색하여 데이터를 수집할 수 있습니다.
                    </p>
                  )}
                </div>
              </div>
            ) : (
              <>
              <div className="summary-stats">
                <div className="summary-stat">
                  <span className="summary-label">총 수집 항목:</span>
                  <span className="summary-value">{platformSummary.totalItems}개</span>
                </div>
                {(platformSummary.totalComments > 0 || platformSummary.platform === 'youtube' || platformSummary.platform === 'twitter' || platformSummary.platform === 'instagram' || platformSummary.platform === 'facebook' || platformSummary.platform === 'threads' || platformSummary.platform === 'dcinside') && (
                  <div className="summary-stat">
                    <span className="summary-label">총 댓글:</span>
                    <span className="summary-value">{platformSummary.totalComments || 0}개</span>
                  </div>
                )}
                {(platformSummary.totalVideos > 0 || platformSummary.platform === 'youtube') && (
                  <div className="summary-stat">
                    <span className="summary-label">총 영상:</span>
                    <span className="summary-value">{platformSummary.totalVideos || 0}개</span>
                  </div>
                )}
                {(platformSummary.totalTweets > 0 || platformSummary.platform === 'twitter') && (
                  <div className="summary-stat">
                    <span className="summary-label">총 트윗:</span>
                    <span className="summary-value">{platformSummary.totalTweets || 0}개</span>
                  </div>
                )}
                {(platformSummary.totalPosts > 0 || platformSummary.platform === 'instagram' || platformSummary.platform === 'facebook' || platformSummary.platform === 'threads' || platformSummary.platform === 'dcinside') && (
                  <div className="summary-stat">
                    <span className="summary-label">총 게시물:</span>
                    <span className="summary-value">{platformSummary.totalPosts || 0}개</span>
                  </div>
                )}
                {(platformSummary.totalEntries > 0 || platformSummary.platform === 'rss') && (
                  <div className="summary-stat">
                    <span className="summary-label">총 항목:</span>
                    <span className="summary-value">{platformSummary.totalEntries || 0}개</span>
                  </div>
                )}
                </div>
                
                {/* YouTube 플랫폼 댓글 분석 및 요약 */}
                {platformSummary.platform === 'youtube' && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>📊 댓글 분석 및 요약
                        {platformSummary.scans && platformSummary.scans.length > 0 && (() => {
                          const archiveScan = platformSummary.scans.find(scan => {
                            const keyword = (scan.keyword || '').toLowerCase();
                            return keyword.includes('akaiv studio') ||
                                   keyword.includes('akaiv');
                          });
                          return archiveScan ? ' (AkaiV Studio)' : '';
                        })()}
                      </h4>
                      {platformSummary.analysis && platformSummary.analysis.overall_score !== undefined && (
                        <div className={`score-badge score-${platformSummary.analysis.overall_score >= 70 ? 'high' : platformSummary.analysis.overall_score >= 40 ? 'medium' : 'low'}`}>
                          {platformSummary.analysis.overall_score}점
              </div>
            )}
                    </div>
                    
                    {/* 데이터가 없을 때 안내 메시지 */}
                    {(!platformSummary.analysis && platformSummary.totalComments === 0 && (!platformSummary.comment_samples || platformSummary.comment_samples.length === 0)) && (
                      <div className="analysis-section">
                        <p className="analysis-summary" style={{ color: '#666', fontStyle: 'italic' }}>
                          AkaiV Studio 관련 데이터를 수집하려면 YouTube 크롤러를 실행해주세요.
                          <br />
                          키워드: "AkaiV Studio", "AkaiV Studio", "Akaiv Studio" 등
                        </p>
          </div>
        )}
                    
                    {/* 감성 분석 */}
                    {platformSummary.analysis && platformSummary.analysis.sentiment ? (
                      <div className="analysis-section">
                        <div className="analysis-label">감성 분석</div>
                        <div className={`sentiment-badge sentiment-${platformSummary.analysis.sentiment}`}>
                          {platformSummary.analysis.sentiment === 'positive' ? '긍정적' : platformSummary.analysis.sentiment === 'negative' ? '부정적' : '중립적'}
      </div>
                        {platformSummary.analysis.sentiment_distribution && (
                          <div className="sentiment-distribution">
                            <div className="sentiment-bar">
                              <div className="sentiment-positive" style={{ width: `${Math.round((platformSummary.analysis.sentiment_distribution.positive || 0) * 100)}%` }}></div>
                              <div className="sentiment-neutral" style={{ width: `${Math.round((platformSummary.analysis.sentiment_distribution.neutral || 0) * 100)}%` }}></div>
                              <div className="sentiment-negative" style={{ width: `${Math.round((platformSummary.analysis.sentiment_distribution.negative || 0) * 100)}%` }}></div>
                            </div>
                            <div className="sentiment-labels">
                              <span>긍정 {Math.round((platformSummary.analysis.sentiment_distribution.positive || 0) * 100)}%</span>
                              <span>중립 {Math.round((platformSummary.analysis.sentiment_distribution.neutral || 0) * 100)}%</span>
                              <span>부정 {Math.round((platformSummary.analysis.sentiment_distribution.negative || 0) * 100)}%</span>
                            </div>
                          </div>
                        )}
                      </div>
                    ) : (
                      <div className="analysis-section">
                        <div className="analysis-label">감성 분석</div>
                        <div className="sentiment-distribution">
                          <div className="sentiment-bar">
                            <div className="sentiment-positive" style={{ width: '0%' }}></div>
                            <div className="sentiment-neutral" style={{ width: '100%' }}></div>
                            <div className="sentiment-negative" style={{ width: '0%' }}></div>
                          </div>
                          <div className="sentiment-labels">
                            <span>긍정 0%</span>
                            <span>중립 0%</span>
                            <span>부정 0%</span>
                          </div>
                        </div>
                      </div>
                    )}
                    
                    {/* 댓글 요약 */}
                    <div className="analysis-section">
                      <div className="analysis-label">📝 댓글 요약</div>
                      {platformSummary.analysis && platformSummary.analysis.summary ? (
                        <p className="analysis-summary">{platformSummary.analysis.summary}</p>
                      ) : (
                        <p className="analysis-summary">
                          {platformSummary.totalComments > 0 ? (
                            <>
                              총 {platformSummary.totalComments}개의 댓글이 수집되었습니다.
                              {platformSummary.totalVideos > 0 && ` ${platformSummary.totalVideos}개의 영상에서 수집되었습니다.`}
                            </>
                          ) : (
                            '댓글 분석 중입니다...'
                          )}
                        </p>
                      )}
                    </div>
                    
                    {/* 국가별 통계 */}
                    {platformSummary.country_stats && (
                      <div className="analysis-section">
                        <div className="analysis-label">🌍 국가별 통계</div>
                        <div className="country-stats-grid">
                          {['KR', 'US', 'JP', 'Other'].map((countryCode) => {
                            const stats = platformSummary.country_stats[countryCode] || {comments: 0, likes: 0};
                            const countryNames = {'KR': '한국', 'US': '미국', 'JP': '일본', 'Other': '기타'};
                            const countryFlags = {'KR': '🇰🇷', 'US': '🇺🇸', 'JP': '🇯🇵', 'Other': '🌐'};
                            
                            const comments = typeof stats.comments === 'number' ? stats.comments : parseInt(stats.comments || 0, 10);
                            const likes = typeof stats.likes === 'number' ? stats.likes : parseInt(stats.likes || 0, 10);
                            
                            return (
                              <div key={countryCode} className="country-stat-item">
                                <div className="country-flag">{countryFlags[countryCode]}</div>
                                <div className="country-name">{countryNames[countryCode]}</div>
                                <div className="country-numbers">
                                  <span className="country-comments">💬 {comments}</span>
                                  <span className="country-likes">👍 {likes}</span>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>
                    )}
                    
                    {/* 주요 키워드 */}
                    {platformSummary.analysis && platformSummary.analysis.keywords && platformSummary.analysis.keywords.length > 0 ? (
                      <div className="analysis-section">
                        <div className="analysis-label">주요 키워드</div>
                        <div className="keywords-list">
                          {platformSummary.analysis.keywords.slice(0, 5).map((keyword, idx) => (
                            <span key={idx} className="keyword-tag">{keyword}</span>
                          ))}
                        </div>
                      </div>
                    ) : null}
                    
                    {/* 인사이트 */}
                    {platformSummary.analysis && platformSummary.analysis.insights && platformSummary.analysis.insights.length > 0 ? (
                      <div className="analysis-section">
                        <div className="analysis-label">핵심 인사이트</div>
                        <ul className="insights-list">
                          {platformSummary.analysis.insights.slice(0, 3).map((insight, idx) => (
                            <li key={idx}>{insight}</li>
                          ))}
                        </ul>
                      </div>
                    ) : null}
                    
                    {/* 댓글 요약 */}
                    {platformSummary.comment_samples && platformSummary.comment_samples.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">📝 댓글 요약 ({platformSummary.comment_samples.length}개)</div>
                        <div className="comments-list">
                          {platformSummary.comment_samples.slice(0, 5).map((comment, idx) => (
                            <div key={idx} className="comment-item">
                              <div className="comment-header">
                                <span className="comment-author">{comment.author || '익명'}</span>
                                <div className="comment-header-right">
                                  {comment.sentiment && (
                                    <span className={`comment-sentiment sentiment-${comment.sentiment}`}>
                                      {comment.sentiment === 'positive' ? '😊 긍정' : comment.sentiment === 'negative' ? '😢 부정' : '😐 중립'}
                                    </span>
                                  )}
                                  {comment.like_count > 0 && (
                                    <span className="comment-likes">👍 {comment.like_count}</span>
                                  )}
                                </div>
                              </div>
                              <p className="comment-text">{comment.text}</p>
                              <div className="comment-meta">
                                <div className="comment-meta-row">
                                  {comment.published_at ? (
                                    <span className="comment-date">📅 {toKSTDateShort(comment.published_at)}</span>
                                  ) : (
                                    <span className="comment-date" style={{ opacity: 0.6 }}>📅 날짜 정보 없음</span>
                                  )}
                                </div>
                                {comment.video_title && (
                                  <div className="comment-video">
                                    {(() => {
                                      // video_url이 있으면 사용, 없으면 video_id로 생성, 둘 다 없으면 텍스트만 표시
                                      let videoUrl = comment.video_url;
                                      if (!videoUrl && comment.video_id) {
                                        videoUrl = `https://www.youtube.com/watch?v=${comment.video_id}`;
                                      }
                                      return videoUrl ? (
                                        <a href={videoUrl} target="_blank" rel="noopener noreferrer" className="video-link">
                                          📹 {comment.video_title}
                                        </a>
                                      ) : (
                                        <span>📹 {comment.video_title}</span>
                                      );
                                    })()}
                                  </div>
                                )}
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {/* 다른 플랫폼별 분석 섹션 */}
                {platformSummary.platform === 'twitter' && platformSummary.totalTweets > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>🐦 트윗 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 트윗 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalTweets}개의 트윗이 수집되었습니다.
                        {platformSummary.totalComments > 0 && ` 댓글 ${platformSummary.totalComments}개가 수집되었습니다.`}
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">최근 수집 키워드</div>
                        <div className="keywords-list">
                          {[...new Set(platformSummary.scans.map(s => s.keyword).filter(Boolean))].slice(0, 5).map((keyword, idx) => (
                            <span key={idx} className="keyword-tag">{keyword}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {platformSummary.platform === 'telegram' && platformSummary.totalItems > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>💬 Telegram 채널 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 메시지 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalItems}개의 채널에서 데이터가 수집되었습니다.
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">수집된 채널</div>
                        <div className="keywords-list">
                          {platformSummary.scans.slice(0, 5).map((scan, idx) => (
                            <span key={idx} className="keyword-tag">{scan.channel || scan.keyword || 'Unknown'}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {platformSummary.platform === 'rss' && platformSummary.totalEntries > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>📰 RSS 피드 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 피드 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalEntries}개의 RSS 항목이 수집되었습니다.
                        {platformSummary.totalItems > 0 && ` ${platformSummary.totalItems}개의 피드에서 수집되었습니다.`}
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">수집된 피드</div>
                        <div className="keywords-list">
                          {platformSummary.scans.slice(0, 5).map((scan, idx) => (
                            <span key={idx} className="keyword-tag">{scan.keyword || 'RSS Feed'}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {platformSummary.platform === 'instagram' && platformSummary.totalPosts > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>📷 Instagram 게시물 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 게시물 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalPosts}개의 게시물이 수집되었습니다.
                        {platformSummary.totalComments > 0 && ` 댓글 ${platformSummary.totalComments}개가 수집되었습니다.`}
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">최근 수집 키워드</div>
                        <div className="keywords-list">
                          {[...new Set(platformSummary.scans.map(s => s.keyword).filter(Boolean))].slice(0, 5).map((keyword, idx) => (
                            <span key={idx} className="keyword-tag">{keyword}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {platformSummary.platform === 'facebook' && platformSummary.totalPosts > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>👥 Facebook 게시물 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 게시물 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalPosts}개의 게시물이 수집되었습니다.
                        {platformSummary.totalComments > 0 && ` 댓글 ${platformSummary.totalComments}개가 수집되었습니다.`}
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">최근 수집 키워드</div>
                        <div className="keywords-list">
                          {[...new Set(platformSummary.scans.map(s => s.keyword).filter(Boolean))].slice(0, 5).map((keyword, idx) => (
                            <span key={idx} className="keyword-tag">{keyword}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {platformSummary.platform === 'threads' && platformSummary.totalPosts > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>🧵 Threads 게시물 분석</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 게시물 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalPosts}개의 게시물이 수집되었습니다.
                        {platformSummary.totalComments > 0 && ` 댓글 ${platformSummary.totalComments}개가 수집되었습니다.`}
                      </p>
                    </div>
                    {platformSummary.scans && platformSummary.scans.length > 0 && (
                      <div className="analysis-section">
                        <div className="analysis-label">최근 수집 키워드</div>
                        <div className="keywords-list">
                          {[...new Set(platformSummary.scans.map(s => s.keyword).filter(Boolean))].slice(0, 5).map((keyword, idx) => (
                            <span key={idx} className="keyword-tag">{keyword}</span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {/* Vuddy 플랫폼 분석 */}
                {platformSummary.platform === 'vuddy' && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>🎭 Vuddy 크리에이터 요약</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 수집 통계</div>
                      {vuddyCreators && vuddyCreators.length > 0 ? (
                        <>
                          <p className="analysis-summary">
                            총 {vuddyCreators.length}명의 크리에이터 데이터가 수집되었습니다.
                            {vuddyCreators.reduce((sum, c) => sum + (c.total_comments || 0), 0) > 0 &&
                              ` 전체 댓글 ${vuddyCreators.reduce((sum, c) => sum + (c.total_comments || 0), 0)}개, 좋아요 ${vuddyCreators.reduce((sum, c) => sum + (c.total_likes || 0), 0)}개가 수집되었습니다.`}
                          </p>

                          {/* Google 검색 요약 */}
                          {vuddyCreators.some(c => c.google_links && c.google_links.length > 0) && (
                            <div className="google-summary">
                              <div className="analysis-label">🔍 Google 검색 요약</div>
                              <p className="analysis-summary">
                                총 {vuddyCreators.reduce((sum, c) => sum + (c.google_links?.length || 0), 0)}개의 Google 검색 결과가 수집되었습니다.
                              </p>
                              <div className="google-results-preview">
                                {vuddyCreators
                                  .filter(c => c.google_links && c.google_links.length > 0)
                                  .slice(0, 3)
                                  .map((creator, idx) => (
                                    <div key={idx} className="google-creator-preview">
                                      <div className="creator-name-preview">
                                        <strong>{creator.name}</strong>: {creator.google_links.length}개 결과
                                      </div>
                                      {creator.google_links.slice(0, 2).map((link, linkIdx) => (
                                        <div key={linkIdx} className="google-link-preview">
                                          • {link.title && link.title.length > 60 ? link.title.substring(0, 60) + '...' : link.title}
                                        </div>
                                      ))}
                                    </div>
                                  ))}
                              </div>
                            </div>
                          )}

                          {/* 크리에이터 목록 미리보기 */}
                          <div className="creators-preview">
                            <div className="analysis-label">크리에이터 목록</div>
                            <div className="keywords-list">
                              {vuddyCreators.slice(0, 10).map((creator, idx) => (
                                <span key={idx} className="keyword-tag">{creator.name}</span>
                              ))}
                              {vuddyCreators.length > 10 && (
                                <span className="keyword-tag" style={{ opacity: 0.6 }}>+{vuddyCreators.length - 10}명</span>
                              )}
                            </div>
                          </div>
                        </>
                      ) : (
                        <p className="analysis-summary" style={{ color: '#666', fontStyle: 'italic' }}>
                          Vuddy 크리에이터 데이터를 수집하려면 크롤러를 실행해주세요.
                        </p>
                      )}
                    </div>
                  </div>
                )}

                {/* DC인사이드 플랫폼 분석 */}
                {platformSummary.platform === 'dcinside' && platformSummary.totalPosts > 0 && (
                  <div className="platform-analysis">
                    <div className="analysis-header">
                      <h4>💬 DC인사이드 갤러리 요약</h4>
                    </div>
                    <div className="analysis-section">
                      <div className="analysis-label">📊 수집 통계</div>
                      <p className="analysis-summary">
                        총 {platformSummary.totalPosts}개의 게시글이 수집되었습니다.
                        {platformSummary.totalComments > 0 && ` 댓글 ${platformSummary.totalComments}개가 수집되었습니다.`}
                      </p>

                      {/* 감정 분석 요약 */}
                      {(platformSummary.positiveCount > 0 || platformSummary.negativeCount > 0) && (
                        <div className="sentiment-summary">
                          <div className="analysis-label">😊 감정 분석</div>
                          <div className="sentiment-stats">
                            <div className="sentiment-stat-item">
                              <span className="sentiment-emoji">😊</span>
                              <span className="sentiment-label">긍정:</span>
                              <span className="sentiment-count">{platformSummary.positiveCount}개</span>
                            </div>
                            <div className="sentiment-stat-item">
                              <span className="sentiment-emoji">😞</span>
                              <span className="sentiment-label">부정:</span>
                              <span className="sentiment-count">{platformSummary.negativeCount}개</span>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* 갤러리 목록 미리보기 */}
                      {platformSummary.galleries && platformSummary.galleries.length > 0 && (
                        <div className="galleries-preview">
                          <div className="analysis-label">📚 갤러리 목록</div>
                          <div className="keywords-list">
                            {platformSummary.galleries.map((gallery, idx) => (
                              <span key={idx} className="keyword-tag">
                                {gallery.gallery_name} ({gallery.total_posts}개)
                              </span>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </>
            )}
          </div>
        )}
      </div>

      {/* DC인사이드 갤러리 */}
      {console.log('🎨 Rendering DC인사이드 section, galleries count:', dcinsideGalleries.length,
                   'Gallery IDs:', dcinsideGalleries.map(g => g.gallery_id).join(', '))}
      {dcinsideGalleries.length > 0 && (
        <div className="dcinside-section" style={{ marginBottom: '40px' }}>
          <h2 style={{ color: '#0253fe', marginBottom: '20px', fontWeight: '900', textTransform: 'uppercase' }}>
            💬 DC인사이드 갤러리 모니터링 ({dcinsideGalleries.length}개 갤러리)
          </h2>
          <div className="dcinside-galleries-grid" style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(350px, 1fr))', gap: '20px' }}>
            {dcinsideGalleries.map((gallery) => (
              <div
                key={gallery.gallery_id}
                className="dcinside-gallery-card"
                style={{
                  background: '#FFFFFF',
                  border: '3px solid #0253fe',
                  borderRadius: '12px',
                  padding: '20px',
                  transition: 'all 0.3s ease'
                }}
              >
                <h3 style={{ color: '#0253fe', marginBottom: '15px', fontSize: '18px', fontWeight: '900' }}>
                  {gallery.gallery_name}
                </h3>

                {/* 갤러리 통계 */}
                <div style={{ marginBottom: '15px', padding: '15px', background: '#f8f9ff', borderRadius: '8px', border: '2px solid #0253fe' }}>
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '10px', fontSize: '13px', fontWeight: 'bold', color: '#0253fe' }}>
                    <div>📝 게시글: {gallery.total_posts}개</div>
                    <div>💬 댓글: {gallery.total_comments}개</div>
                    <div>👍 긍정: {gallery.positive_count}개</div>
                    <div>👎 부정: {gallery.negative_count}개</div>
                  </div>
                  {gallery.crawled_at && (
                    <div style={{ marginTop: '10px', fontSize: '11px', color: '#0253fe', opacity: 0.7 }}>
                      수집 시간: {new Date(gallery.crawled_at).toLocaleString('ko-KR')}
                    </div>
                  )}
                </div>

                {/* 키워드 */}
                {gallery.keywords && gallery.keywords.length > 0 && (
                  <div style={{ marginBottom: '15px' }}>
                    <div style={{ fontSize: '12px', color: '#0253fe', marginBottom: '8px', fontWeight: 'bold' }}>
                      🔍 모니터링 키워드:
                    </div>
                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: '6px' }}>
                      {gallery.keywords.slice(0, 8).map((keyword, idx) => (
                        <span
                          key={idx}
                          style={{
                            background: '#0253fe',
                            color: '#cfff0b',
                            padding: '4px 10px',
                            borderRadius: '12px',
                            fontSize: '11px',
                            fontWeight: '900'
                          }}
                        >
                          {keyword}
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                {/* 최근 게시글 */}
                {gallery.posts && gallery.posts.length > 0 && (
                  <div>
                    <div style={{ fontSize: '14px', color: '#0253fe', marginBottom: '10px', fontWeight: '900' }}>
                      📌 최근 게시글:
                    </div>
                    <div style={{ display: 'flex', flexDirection: 'column', gap: '10px' }}>
                      {gallery.posts.slice(0, 20).map((post) => (
                        <div key={post.post_id} style={{ marginBottom: '10px' }}>
                          <a
                            href={post.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            style={{
                              display: 'block',
                              padding: '12px',
                              background: '#FFFFFF',
                              border: '2px solid #0253fe',
                              borderRadius: '8px',
                              textDecoration: 'none',
                              color: '#0253fe',
                              transition: 'all 0.2s ease'
                            }}
                            onMouseEnter={(e) => {
                              e.currentTarget.style.background = '#0253fe';
                              e.currentTarget.style.color = '#cfff0b';
                              e.currentTarget.style.transform = 'translateY(-2px)';
                            }}
                            onMouseLeave={(e) => {
                              e.currentTarget.style.background = '#FFFFFF';
                              e.currentTarget.style.color = '#0253fe';
                              e.currentTarget.style.transform = 'translateY(0)';
                            }}
                          >
                            <div style={{ fontWeight: '900', marginBottom: '6px', fontSize: '13px' }}>
                              {post.matched_keyword && (
                                <span style={{
                                  background: '#0253fe',
                                  color: '#cfff0b',
                                  padding: '2px 6px',
                                  borderRadius: '4px',
                                  fontSize: '10px',
                                  marginRight: '6px'
                                }}>
                                  {post.matched_keyword}
                                </span>
                              )}
                              {(() => {
                                const sentiment = analyzeSentiment(post.title + ' ' + (post.content || ''));
                                if (sentiment === 'positive') {
                                  return <span style={{ marginRight: '6px', fontSize: '14px' }}>😊</span>;
                                } else if (sentiment === 'negative') {
                                  return <span style={{ marginRight: '6px', fontSize: '14px' }}>😞</span>;
                                }
                                return null;
                              })()}
                              {post.title}
                            </div>
                            <div style={{ fontSize: '11px', opacity: 0.8, marginBottom: '4px' }}>
                              <span style={{ fontWeight: 'bold' }}>작성자:</span> {post.author} ·
                              <span style={{ fontWeight: 'bold', marginLeft: '8px' }}>작성일:</span> {post.date}
                            </div>
                            <div style={{ fontSize: '11px', opacity: 0.8, display: 'flex', justifyContent: 'space-between' }}>
                              <span>👁️ 조회 {post.view_count}</span>
                              <span>👍 추천 {post.recommend_count}</span>
                              <span>💬 댓글 {post.comment_count}</span>
                            </div>
                          </a>

                          {/* 댓글 표시 */}
                          {post.comments && post.comments.length > 0 && (
                            <div style={{ marginTop: '8px', paddingLeft: '12px', borderLeft: '3px solid #0253fe' }}>
                              <div style={{ fontSize: '12px', color: '#0253fe', marginBottom: '6px', fontWeight: 'bold' }}>
                                💬 댓글 ({post.comments.length}개)
                              </div>
                              {post.comments.slice(0, 3).map((comment, idx) => {
                                const commentSentiment = analyzeSentiment(comment.text);
                                return (
                                  <div key={idx} style={{ padding: '8px', marginBottom: '6px', background: '#f8f9ff', borderRadius: '6px', fontSize: '11px' }}>
                                    <div style={{ fontWeight: 'bold', color: '#0253fe', marginBottom: '4px' }}>
                                      {commentSentiment === 'positive' && <span style={{ marginRight: '4px' }}>😊</span>}
                                      {commentSentiment === 'negative' && <span style={{ marginRight: '4px' }}>😞</span>}
                                      {comment.author} · {comment.date}
                                    </div>
                                    <div style={{ color: '#0253fe' }}>{comment.text}</div>
                                  </div>
                                );
                              })}
                              {post.comments.length > 3 && (
                                <div style={{ fontSize: '10px', color: '#0253fe', opacity: 0.7, marginTop: '6px' }}>
                                  +{post.comments.length - 3}개 더보기
                                </div>
                              )}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* 채널 목록 */}
      {channels.length > 0 && (
        <div className="channels-section">
          <h2>📺 모니터링 중인 채널</h2>
          <div className="channels-grid">
            {channels.map((channel, index) => {
              // AkaiV Studio 채널인 경우 Vuddy 크리에이터 데이터 표시
              const channelName = (channel.channel_title || channel.channel || '').toLowerCase();
              const isArchiveStudio = channelName.includes('akaiv studio') ||
                                     channelName.includes('akaiv');
              
              // AkaiV Studio 소속 크리에이터들 찾기 (조건 완화: 크리에이터가 없어도 클릭 가능)
              // eslint-disable-next-line no-unused-vars
              const archiveStudioCreators = isArchiveStudio ? allVuddyCreators.filter(c => {
                const name = (c.name || '').toLowerCase();
                return name.includes('u32') || name.includes('여르미') || name.includes('한결') || 
                       name.includes('비몽') || name.includes('샤르망') || name.includes('akaiv');
              }) : [];
              
              const handleChannelCardClick = (e) => {
                // AkaiV Studio인 경우 카드 클릭 시 상세 페이지로 이동 (크리에이터가 없어도 이동 가능)
                if (isArchiveStudio) {
                  // 버튼이나 링크 클릭이 아닌 경우에만 이동
                  const target = e.target;
                  const isClickableElement = target.closest('.channel-link') || 
                                            target.closest('button') || 
                                            target.closest('a') ||
                                            target.closest('.btn-view-details');
                  
                  if (!isClickableElement) {
                    e.preventDefault();
                    e.stopPropagation();
                    console.log('Navigating to AkaiV Studio detail page from channel card');
                    // history.pushState를 사용하여 라우팅 (페이지 새로고침 없이)
            window.history.pushState({}, '', '/akaiv-studio');
            window.dispatchEvent(new PopStateEvent('popstate'));
                  }
                }
              };
              
              return (
              <div 
                key={index} 
                className={`channel-card ${isArchiveStudio ? 'channel-card-clickable' : ''}`}
                onClick={handleChannelCardClick}
                style={isArchiveStudio ? { cursor: 'pointer' } : {}}
              >
                <h3 
                  onClick={isArchiveStudio ? (e) => {
                    e.stopPropagation();
                    console.log('Navigating to AkaiV Studio detail page from channel h3');
                    window.history.pushState({}, '', '/akaiv-studio');
                    window.dispatchEvent(new PopStateEvent('popstate'));
                  } : undefined}
                  style={isArchiveStudio ? { cursor: 'pointer', color: '#667eea', textDecoration: 'underline' } : {}}
                  onMouseEnter={isArchiveStudio ? (e) => e.target.style.color = '#764ba2' : undefined}
                  onMouseLeave={isArchiveStudio ? (e) => e.target.style.color = '#667eea' : undefined}
                >
                  {channel.channel_title || channel.channel}
                  {isArchiveStudio && ' →'}
                </h3>
                {isArchiveStudio && (
                  <div className="akaiv-studio-badge">
                    <span className="badge-text">🎭 AkaiV Studio 소속 크리에이터 분석</span>
                  </div>
                )}
                <div className="channel-stats">
                  <div className="channel-stat">
                    <span className="stat-label">영상 수:</span>
                    <span className="stat-value">{channel.videos_analyzed || 0}</span>
                  </div>
                  <div className="channel-stat">
                    <span className="stat-label">댓글 수:</span>
                    <span className="stat-value">{channel.total_comments || 0}</span>
                  </div>
                  {channel.vtuber_comments > 0 && (
                    <div className="channel-stat">
                      <span className="stat-label">버튜버 댓글:</span>
                      <span className="stat-value">{channel.vtuber_comments}</span>
                    </div>
                  )}
                </div>
                  {isArchiveStudio ? (
                  <div className="channel-link">
                      <button 
                        className="btn-view-details"
                        onClick={(e) => {
                          e.preventDefault();
                          e.stopPropagation();
                          console.log('Navigating to AkaiV Studio detail page from button');
                          // 새 페이지로 이동 (AkaiV Studio 상세 페이지)
                          // history.pushState를 사용하여 라우팅 (페이지 새로고침 없이)
                          window.history.pushState({}, '', '/akaiv-studio');
                          window.dispatchEvent(new PopStateEvent('popstate'));
                        }}
                      >
                      상세 데이터 보기 →
                      </button>
                      <div className="channel-hint">
                        💡 카드를 클릭해도 상세 페이지로 이동합니다
                  </div>
              </div>
                  ) : channel.s3_key ? (
                  <div className="channel-link">
                    <a href={`/api/data/${encodeURIComponent(channel.s3_key)}`} target="_blank" rel="noopener noreferrer">
                      상세 데이터 보기 →
                    </a>
                      </div>
                  ) : null}
                    </div>
              );
            })}
                      </div>
                    </div>
                  )}
                  
    </div>
  );
}

export default Dashboard;

