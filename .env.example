# ==========================================
# SNS Monitor - Environment Configuration
# ==========================================

# YouTube Data API v3 Key (required)
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ==========================================
# Optional Settings (defaults work fine)
# ==========================================

# Search keywords (comma-separated)
SEARCH_KEYWORDS=

# Crawl schedule (cron expression)
CRAWL_SCHEDULE=0 */2 * * *

# Local mode (use local filesystem instead of S3)
LOCAL_MODE=true
LOCAL_DATA_DIR=./local-data

# Redis (used for caching, optional)
REDIS_HOST=redis
REDIS_PORT=6379

# API port
API_PORT=8080

# Frontend port
FRONTEND_PORT=3000

# Debug mode
FLASK_DEBUG=false

# Docker image tag
IMAGE_TAG=latest
