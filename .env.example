# ==========================================
# SNS Monitor - Environment Configuration
# ==========================================

# YouTube Data API v3 Key (required)
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ==========================================
# Optional Settings (defaults work fine)
# ==========================================

# Search keywords (comma-separated)
SEARCH_KEYWORDS=

# Crawl schedule (cron expression)
CRAWL_SCHEDULE=0 */2 * * *

# Local mode (use local filesystem instead of S3)
LOCAL_MODE=true
LOCAL_DATA_DIR=./local-data

# Redis (used for caching, optional)
REDIS_HOST=redis
REDIS_PORT=6379
# Redis host port for host access (default 6380)
REDIS_HOST_PORT=6380

# API port (host)
API_PORT=8888

# Frontend port (host)
FRONTEND_PORT=3080

# Frontend: API base URL (optional). Leave unset for Docker (same-origin) or local dev default (http://localhost:8888).
# REACT_APP_API_URL=http://localhost:8888

# Debug mode
FLASK_DEBUG=false

# Docker image tag
IMAGE_TAG=latest

# ==========================================
# MiroFish AI Analysis (Optional)
# ==========================================
# Start with: docker-compose --profile analysis up -d
# Build context path to mirofish repo (default: ./mirofish)
# MIROFISH_CONTEXT=/path/to/mirofish
MIROFISH_ENDPOINT=http://mirofish:5001
# Keep TLS verification enabled in production (default: true)
MIROFISH_SSL_VERIFY=true

# ==========================================
# OpenAI OAuth (Optional – gate MiroFish/analysis behind login)
# ==========================================
# Set AUTH_REQUIRED_FOR_ANALYSIS=true to require login for analysis/MiroFish.
# OAuth 2.0: use OpenAI or any IdP (Okta, Auth0, etc.) that supports authorization_code.
# SECRET_KEY=your-flask-session-secret
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:8888/api/auth/callback
# OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
# OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
# OAUTH_SCOPES=openid profile email
# FRONTEND_URL=http://localhost:3080
# CORS_ORIGINS=http://localhost:3080
# AUTH_REQUIRED_FOR_ANALYSIS=false

# ==========================================
# Reddit API (Optional – avoids 403 on subreddit/post analysis)
# ==========================================
# Create a "script" or "web" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Optional; Reddit requires a descriptive User-Agent
# REDDIT_USER_AGENT=sns-monitor/1.0 (by your_reddit_username)

# ==========================================
# Naver Cafe Collection (Optional)
# ==========================================
# Naver Search API for cafe article search (register at https://developers.naver.com/apps)
# Enables server-side search when ?q=keyword is used in cafe URLs
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
# Cookie string from authenticated browser session (required for post/comment list;
# get from browser DevTools → Application → Cookies after logging into cafe.naver.com)
NAVER_CAFE_COOKIE=
# Comma-separated list of cafe list URLs for crawler (profile: crawlers)
# Example: https://cafe.naver.com/f-e/cafes/31581843/menus/0?viewType=L
NAVER_CAFE_URLS=
# Proxy for Naver requests (for corporate/internal network)
NAVER_CAFE_PROXY_URL=
NAVER_CAFE_PROXY_USERNAME=
NAVER_CAFE_PROXY_PASSWORD=
# Use only when corporate TLS inspection blocks HTTPS cert chain
NAVER_CAFE_DISABLE_SSL_VERIFY=false
# Avoid setting this to true except temporary local debugging
DISABLE_SSL_VERIFY=false
