# Terraform 변수 설정 예제
# 이 파일을 terraform.tfvars로 복사하고 값을 수정하세요
# cp terraform.tfvars.example terraform.tfvars

# ==========================================
# 기본 설정
# ==========================================

# AWS 리전
aws_region = "ap-northeast-2"

# 환경 (dev, staging, prod)
environment = "dev"

# 프로젝트 이름
project_name = "sns-monitor"

# ==========================================
# 검색 키워드
# ==========================================

# 모니터링할 키워드 목록
search_keywords = ["ExampleCorp", "CreatorBrand", "굿즈"]

# ==========================================
# 크롤링 스케줄
# ==========================================

# 크롤링 실행 스케줄
# rate(30 minutes) = 30분마다
# rate(1 hour) = 1시간마다
# rate(2 hours) = 2시간마다 (비용 절감 50%, 권장)
crawl_schedule = "rate(2 hours)"

# ==========================================
# API 키 설정
# ==========================================

# YouTube Data API v3 키
# 발급: https://console.cloud.google.com/
youtube_api_key = ""

# Twitter API Bearer Token (Basic $100/월)
# 발급: https://developer.twitter.com/
twitter_bearer_token = ""

# Telegram Bot Token (무료)
# 발급: @BotFather (t.me/botfather)
telegram_bot_token = ""

# Instagram Graph API Access Token
# 발급: https://developers.facebook.com/
instagram_access_token = ""

# Telegram 채널 목록 (봇이 관리자여야 함)
telegram_channels = ["@your_channel"]

# ==========================================
# 플랫폼 활성화 (비용 제어)
# ==========================================

# YouTube 활성화 (무료, 권장)
enable_youtube = true

# Twitter 활성화 (비용 주의: $100/월)
# Chrome Extension으로 무료 수집 가능 (권장)
enable_twitter = false

# Telegram 활성화 (무료, 권장)
enable_telegram = true

# Instagram 활성화
enable_instagram = false

# Naver Cafe 활성화 (이용약관 주의)
enable_naver_cafe = false

# RSS 피드 활성화 (무료, 권장)
enable_rss = true

# RSS 피드 URL 목록
# SNS 모니터링에 유용한 한국 주요 뉴스 사이트 RSS 피드
rss_feeds = [
  # IT/과학 뉴스
  "https://news.naver.com/main/rss/section.naver?sid=105",  # 네이버 IT/과학
  "https://news.daum.net/rss/it",                          # 다음 IT
  "https://www.bloter.net/rss",                            # 블로터
  "https://www.zdnet.co.kr/rss/all.xml",                   # ZDNet Korea
  "https://it.chosun.com/rss/all.xml",                     # IT조선
  "https://www.ddaily.co.kr/rss/all.xml",                  # 디지털데일리
  
  # 연예/엔터테인먼트
  "https://news.naver.com/main/rss/section.naver?sid=106", # 네이버 연예
  "https://news.daum.net/rss/entertain",                   # 다음 연예
  "https://www.yna.co.kr/rss/entertainment/10000002.xml", # 연합뉴스 연예
  
  # 경제/비즈니스
  "https://news.naver.com/main/rss/section.naver?sid=101", # 네이버 경제
  "https://www.mk.co.kr/rss/30000041/",                    # 매일경제
  
  # 게임/문화
  "https://www.gamemeca.com/rss/all.xml",                   # 게임메카
  "https://www.inven.co.kr/rss/rss.xml",                    # 인벤
  
  # 추가 RSS 피드 URL...
  # 자세한 목록은 docs/rss-feeds.md 참조
]

# ==========================================
# AI 모델 설정
# ==========================================

# Bedrock 모델 ID
# 비용 절감 (권장): anthropic.claude-3-haiku-20240307-v1:0
# 성능 향상: anthropic.claude-3-5-sonnet-20241022-v2:0
bedrock_model_id = "anthropic.claude-3-haiku-20240307-v1:0"

# Bedrock 리전
bedrock_region = "us-east-1"

# ==========================================
# 멀티 모델 분석 (선택사항)
# ==========================================

# 멀티 모델 분석 활성화
# false: Bedrock만 사용 (기본, 권장)
# true: Bedrock + Claude API + OpenAI 교차 검증 (비용 증가)
enable_multi_model_analysis = false

# Claude API 키 (claude.ai / Claude Code Console)
# 발급: https://console.anthropic.com/
# 비용: ~$3/1M 입력 토큰 (Sonnet)
claude_api_key = ""

# OpenAI API 키 (Cursor Agents 등)
# 발급: https://platform.openai.com/
# 비용: ~$10/1M 입력 토큰 (GPT-4 Turbo)
openai_api_key = ""

# 참고: 멀티 모델 분석 활성화 시 AI 비용 약 3-4배 증가
# 장점: 여러 모델의 교차 검증으로 더 정확한 분석
# 추천: 중요한 키워드만 선택적으로 사용

# ==========================================
# 알림 설정
# ==========================================

# 이메일 알림 (선택사항)
sns_email = ""

# Slack 알림 (선택사항)
slack_webhook_url = ""

# 부정 감성 알림 임계값 (0.0-1.0)
# 0.7 = 부정 비율 70% 이상 시 알림
alert_threshold_negative = 0.7

# ==========================================
# 데이터베이스 설정
# ==========================================

# DynamoDB 빌링 모드
# PAY_PER_REQUEST: 사용량 기반 (소규모 권장)
# PROVISIONED: 프로비저닝 용량
dynamodb_billing_mode = "PAY_PER_REQUEST"

# DynamoDB 데이터 보존 기간 (일)
dynamodb_ttl_days = 90

# ==========================================
# CDN 설정
# ==========================================

# CloudFront 활성화
enable_cloudfront = true

# CloudFront 가격 클래스
# PriceClass_100: 북미, 유럽 (가장 저렴)
# PriceClass_200: 북미, 유럽, 아시아 (권장)
# PriceClass_All: 전 세계
cloudfront_price_class = "PriceClass_200"

# ==========================================
# 보안 설정
# ==========================================

# WAF 활성화 (비용 주의: +$8-10/월)
enable_waf = false

# API Key 인증 활성화 (무료, 권장)
enable_api_key = true

# ==========================================
# 로깅 설정 (비용 절감)
# ==========================================

# CloudWatch Logs 활성화
# false: 로깅 비활성화로 $5-8/월 절감 (비용 절감, 권장)
# true: 로깅 활성화 (디버깅 시에만 사용)
enable_cloudwatch_logs = false

# CloudWatch Logs 보존 기간 (활성화 시)
cloudwatch_retention_days = 3

# ==========================================
# Chrome Extension
# ==========================================

# Chrome Extension용 API 활성화
enable_chrome_extension_api = true

# ==========================================
# 비용 최적화 요약
# ==========================================

# 최소 구성 (~$15-20/월):
# - enable_youtube = true
# - enable_telegram = true
# - enable_twitter = false
# - enable_cloudwatch_logs = false
# - crawl_schedule = "rate(1 hour)"
# - bedrock_model_id = "claude-3-haiku"
# - Chrome Extension으로 수동 수집 병행

# 표준 구성 (~$30-40/월):
# - enable_youtube = true
# - enable_telegram = true
# - enable_instagram = true
# - crawl_schedule = "rate(30 minutes)"
# - bedrock_model_id = "claude-3-haiku"

# 실시간 구성 (~$120-150/월):
# - 모든 플랫폼 활성화 (Twitter 포함)
# - crawl_schedule = "rate(15 minutes)"
# - bedrock_model_id = "claude-3-5-sonnet"
# - enable_waf = true
# - enable_cloudwatch_logs = true

# ==========================================
# API 비용 참고
# ==========================================

# YouTube Data API v3: 무료 (10,000 유닛/일)
# Twitter Basic API: $100/월
# Telegram Bot API: 무료
# Instagram Graph API: 무료 (제한적)
# Bedrock Claude Haiku: ~$0.25/1M 입력 토큰
# Bedrock Claude Sonnet: ~$3/1M 입력 토큰
